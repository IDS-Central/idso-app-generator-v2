{
    "compilerOptions": {
          "target": "ES2022",
          "module": "ES2022",
          "moduleResolution": "node",
          "lib": ["ES2022"],
          "outDir": "dist",
          "rootDir": "src",
          "strict": true,
          "noUncheckedIndexedAccess": true,
          "noImplicitOverride": true,
          "esModuleInterop": true,
          "forceConsistentCasingInFileNames": true,
          "resolveJsonModule": true,
          "skipLibCheck": true,
          "sourceMap": true,
          "declaration": false
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
